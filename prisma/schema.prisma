generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String
  showSubtasks   Boolean         @default(true)
  theme          String          @default("dark")
  accentColor    String          @default("blue")
  workboards     Workboard[]
  tasks          Task[]
  comments       Comment[]       @relation("UserComments")
  attachments    Attachment[]
  activityLogs   ActivityLog[]   @relation("UserActivity")
  jiraConnection JiraConnection?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Workboard {
  id          String   @id @default(cuid())
  name        String
  key         String
  description String?
  taskCounter Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, key])
}

model Task {
  id             String    @id @default(cuid())
  taskNumber     Int
  title          String
  description    String?   @db.Text
  jiraUrl        String?
  priority       Int       @default(1)
  status         Int       @default(1)
  dueDate        DateTime?
  parentId       String?
  subtaskNumber  Int?
  sortOrder      Int       @default(0)
  userId         String
  workboardId    String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workboard      Workboard @relation(fields: [workboardId], references: [id], onDelete: Cascade)
  parent         Task?     @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks       Task[]    @relation("Subtasks")
  jiraIssueId    String?
  jiraIssueKey   String?
  jiraSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  comments       Comment[]
  attachments    Attachment[]
  activityLogs   ActivityLog[]

  @@unique([workboardId, taskNumber])
  @@unique([parentId, subtaskNumber])
  @@unique([userId, jiraIssueId])
}

model Comment {
  id          String       @id @default(cuid())
  content     String       @db.Text
  taskId      String
  userId      String
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([taskId, createdAt])
}

model JiraConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  cloudId      String
  cloudName    String
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attachment {
  id          String   @id @default(cuid())
  r2Key       String
  url         String
  filename    String
  contentType String
  size        Int
  taskId      String?
  commentId   String?
  userId      String
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([commentId])
  @@index([userId, taskId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  metadata  Json?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("UserActivity", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}
